# Copie para docker/.env com ./scripts/docker-init-env.sh.

COMPOSE_PROJECT_NAME=vulcan
VULCAN_BIND_HOST=127.0.0.1
VULCAN_DB_PORT=55432
BACKEND_PORT=3001
FRONTEND_PORT=3002
# A Evolution do stack principal fica interna no Docker. Use a porta apenas no runtime standalone/owner.
EVOLUTION_PORT=8080

POSTGRES_PASSWORD=postgres
EVOLUTION_POSTGRES_DATABASE=evolution
EVOLUTION_POSTGRES_USERNAME=evolution
EVOLUTION_POSTGRES_PASSWORD=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_LOCAL_TEST_AUTH=true
NEXT_PUBLIC_MOCK_AUTH=false
NEXT_PUBLIC_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000301
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@vulcan.local
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=VulcanAdmin123!
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me

AUTH_PROVIDER=supabase
MOCK_AUTH=false
MOCK_DATA=false
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin
LOCAL_TEST_AUTH_ENABLED=true
LOCAL_TEST_USERNAME=teste
LOCAL_TEST_PASSWORD=teste
SUPABASE_DEMO_ADMIN_EMAIL=admin@vulcan.local
SUPABASE_DEMO_ADMIN_PASSWORD=VulcanAdmin123!

API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002
API_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1):[0-9]+$

EMAIL_PROVIDER=smtp
EMAIL_DELIVERY_MODE=mock

ROOT_WHATSAPP_ENABLED=false
ROOT_WHATSAPP_PROVIDER=evolution
ROOT_WHATSAPP_NUMBER=
ROOT_WHATSAPP_NAME=Vulcan Notifications
ROOT_WHATSAPP_MOCK_MODE=false
WHATSAPP_PROVIDER=evolution
WHATSAPP_DEFAULT_COUNTRY=BR
WHATSAPP_REQUIRE_OPT_IN=true
WHATSAPP_ENABLE_UNOFFICIAL_PROVIDER=true
WHATSAPP_EMAIL_FALLBACK_ENABLED=true
WHATSAPP_IN_APP_FALLBACK_ENABLED=true
WHATSAPP_WORKER_POLL_SECONDS=10

EVOLUTION_ENABLED=true
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_INSTANCE_NAME=vulcan-root
EVOLUTION_WEBHOOK_URL=http://backend:3001/integrations/whatsapp/evolution/webhook
EVOLUTION_REQUEST_ORIGIN=http://evolution:8080
EVOLUTION_CORS_ORIGIN=http://evolution:8080,http://vulcan-backend:3001
EVOLUTION_REQUEST_TIMEOUT_SECONDS=30
EVOLUTION_MAX_RETRIES=3
EVOLUTION_RETRY_BACKOFF_SECONDS=5
VULCAN_ALLOW_RUNTIME_INTEGRATION_CONFIG=true

AGENT_ENROLLMENT_TOKEN=vulcan-local-enrollment-token

AI_PROVIDER=hybrid
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
AI_COMPLEX_MODEL=gpt-5.5
AI_OPERATIONAL_MODEL=llama-4-maverick
LLAMA_PROVIDER=openai-compatible
LLAMA_BASE_URL=http://host.docker.internal:11434/v1
LLAMA_MODEL=llama-4-maverick
LLAMA_API_KEY=
