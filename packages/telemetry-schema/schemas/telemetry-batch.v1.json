{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/telemetry-batch.v1.json",
  "title": "TelemetryBatchRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sentAt", "events"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "2026-04-telemetry.v1"
    },
    "batchId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "sentAt": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workstationId"],
      "properties": {
        "workstationId": {
          "type": "string",
          "format": "uuid"
        },
        "agentInstallationId": {
          "type": "string",
          "format": "uuid"
        },
        "agentVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "eventType", "occurredAt", "source", "payload"],
      "properties": {
        "eventId": {
          "type": "string",
          "format": "uuid"
        },
        "eventType": {
          "type": "string",
          "enum": [
            "heartbeat",
            "session_lock",
            "session_unlock",
            "session_login",
            "session_logout",
            "idle_start",
            "idle_end",
            "foreground_application_change",
            "process_start",
            "process_stop"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
