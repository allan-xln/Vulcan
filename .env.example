# Global
COMPOSE_PROJECT_NAME=vulcan
NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_APP_NAME=Vulcan
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
NEXT_PUBLIC_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000301
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@vulcan.local
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=replace-local-demo-password

# Supabase platform
AUTH_PROVIDER=supabase
MOCK_AUTH=false
MOCK_DATA=false
NEXT_PUBLIC_MOCK_AUTH=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_REST_URL=https://your-project.supabase.co/rest/v1
SUPABASE_PROJECT_REF=replace-me
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_SECRET_KEY=replace-me
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace-me
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vulcan
DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vulcan

# Local fallback auth for development only
LOCAL_AUTH_USER_ID=11111111-1111-1111-1111-111111111111
LOCAL_AUTH_USER_EMAIL=owner@local.test
LOCAL_API_HOST=0.0.0.0
LOCAL_API_PORT=3001
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin
LOCAL_TEST_AUTH_ENABLED=true
LOCAL_TEST_USERNAME=teste
LOCAL_TEST_PASSWORD=teste
NEXT_PUBLIC_LOCAL_TEST_AUTH=true
SUPABASE_DEMO_ADMIN_EMAIL=admin@vulcan.local
SUPABASE_DEMO_ADMIN_PASSWORD=replace-local-demo-password

# AI service
AI_PROVIDER=hybrid
AI_API_HOST=0.0.0.0
AI_API_PORT=8000
AI_API_ALLOWED_ORIGINS=http://localhost:3000
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.5
AI_COMPLEX_MODEL=gpt-5.5
AI_OPERATIONAL_MODEL=llama-4-maverick
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_OUTPUT_TOKENS=2000
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
LLAMA_PROVIDER=openai-compatible
LLAMA_BASE_URL=http://localhost:11434/v1
LLAMA_MODEL=llama-4-maverick
LLAMA_API_KEY=

# Notifications
