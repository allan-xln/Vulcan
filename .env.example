# Global
COMPOSE_PROJECT_NAME=telemetry-saas-lab
NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_APP_NAME=Telemetry Control Plane
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# Control plane and auth
SUPABASE_SERVICE_ROLE_KEY=replace-me
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/telemetry_app
LOCAL_AUTH_USER_ID=11111111-1111-1111-1111-111111111111
LOCAL_AUTH_USER_EMAIL=owner@local.test

# Analytics
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=telemetry
REDIS_URL=redis://localhost:6379/0

# AI service
AI_API_HOST=0.0.0.0
AI_API_PORT=8000
AI_API_ALLOWED_ORIGINS=http://localhost:3000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Query API
QUERY_API_HOST=0.0.0.0
QUERY_API_PORT=8020

# Agent ingestion
INGESTION_SHARED_SECRET=replace-me
INGESTION_API_HOST=0.0.0.0
INGESTION_API_PORT=8010
INGESTION_SCHEMA_VERSION=2026-04-telemetry.v1
INGESTION_API_KEY_ID=00000000-0000-0000-0000-000000001501
INGESTION_API_KEY=local-ingestion-key-change-me
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
